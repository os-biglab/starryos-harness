[
  {
    "id": "negative-to-unsigned-cast",
    "description": "Casting negative error codes to unsigned types (e.g., -1 as u32)",
    "grep_pattern": "as\\s+(u8|u16|u32|u64|usize)",
    "file_glob": "**/*.rs",
    "exclude_pattern": "test|mock|example",
    "context_lines": 2,
    "severity": "P1",
    "category": "Correctness",
    "discovered_from": "starry-harness default rules"
  },
  {
    "id": "ok-zero-stub",
    "description": "Ok(0) or Ok(()) placeholder stub that silently succeeds without real implementation",
    "grep_pattern": "Ok\\((0|\\(\\))\\)\\s*//",
    "file_glob": "**/*.rs",
    "exclude_pattern": "test|mock",
    "context_lines": 3,
    "severity": "P2",
    "category": "Semantic",
    "discovered_from": "starry-harness default rules"
  },
  {
    "id": "catch-all-match-arm",
    "description": "Wildcard match arm (_) that silently catches unexpected variants",
    "grep_pattern": "_\\s*=>\\s*(Ok|return|continue|break)",
    "file_glob": "**/*.rs",
    "exclude_pattern": "test|mock",
    "context_lines": 3,
    "severity": "P2",
    "category": "Semantic",
    "discovered_from": "starry-harness default rules"
  },
  {
    "id": "todo-fixme-hack",
